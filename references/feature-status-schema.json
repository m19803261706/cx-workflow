{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "cx-workflow 3.0 Feature Status Schema",
  "description": "Schema for .claude/cx/功能/<feature>/状态.json — execution state for a single feature",
  "type": "object",
  "required": [
    "feature",
    "slug",
    "created_at",
    "last_updated",
    "status",
    "total",
    "completed",
    "in_progress",
    "phases",
    "tasks",
    "execution_order",
    "docs"
  ],
  "properties": {
    "feature": {
      "type": "string",
      "description": "Chinese display title"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9_-]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "last_updated": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "drafting",
        "planned",
        "executing",
        "blocked",
        "completed",
        "summarized"
      ]
    },
    "total": {
      "type": "integer",
      "minimum": 0
    },
    "completed": {
      "type": "integer",
      "minimum": 0
    },
    "in_progress": {
      "type": "integer",
      "minimum": 0
    },
    "blocked": {
      "type": "object",
      "required": ["reason_type", "message"],
      "properties": {
        "reason_type": {
          "type": "string",
          "enum": [
            "needs_decision",
            "missing_external_info",
            "dependency_unmet",
            "verification_failed",
            "environment_issue",
            "integration_conflict"
          ]
        },
        "message": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "phases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["number", "name", "status", "tasks"],
        "properties": {
          "number": {
            "type": "integer",
            "minimum": 1
          },
          "name": {
            "type": "string"
          },
          "parallel_group": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["pending", "ready", "in_progress", "blocked", "completed"]
          },
          "tasks": {
            "type": "array",
            "items": {
              "type": "integer",
              "minimum": 1
            }
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "additionalProperties": false
      }
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "number",
          "title",
          "phase",
          "parallel",
          "depends_on",
          "status"
        ],
        "properties": {
          "number": {
            "type": "integer",
            "minimum": 1
          },
          "title": {
            "type": "string"
          },
          "phase": {
            "type": "integer",
            "minimum": 1
          },
          "parallel": {
            "type": "boolean"
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "integer",
              "minimum": 1
            }
          },
          "parallel_group": {
            "type": "string"
          },
          "related_apis": {
            "type": "array",
            "items": {
              "type": ["integer", "string"]
            }
          },
          "related_enums": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "related_fields": {
            "type": "array",
            "items": {
              "type": ["integer", "string"]
            }
          },
          "status": {
            "type": "string",
            "enum": ["pending", "ready", "in_progress", "blocked", "completed"]
          },
          "reason_type": {
            "type": "string",
            "enum": [
              "needs_decision",
              "missing_external_info",
              "dependency_unmet",
              "verification_failed",
              "environment_issue",
              "integration_conflict"
            ]
          },
          "commit": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "execution_order": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "integer",
            "minimum": 1
          },
          {
            "type": "array",
            "items": {
              "type": "integer",
              "minimum": 1
            }
          }
        ]
      }
    },
    "worktree": {
      "type": "object",
      "properties": {
        "preferred_branch": {
          "type": "string"
        },
        "preferred_worktree_path": {
          "type": "string"
        },
        "binding_status": {
          "type": "string",
          "enum": ["unbound", "recommended", "bound"]
        },
        "isolation_mode": {
          "type": "string",
          "enum": ["worktree", "inline", "merged"],
          "description": "worktree=独立工作区, inline=当前分支, merged=已合并回主分支"
        },
        "bound_at": {
          "type": ["string", "null"],
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "docs": {
      "type": "object",
      "required": ["prd"],
      "properties": {
        "prd": {
          "type": "string"
        },
        "design": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "workflow": {
      "type": "object",
      "required": [
        "protocol_version",
        "current_phase",
        "completion_status",
        "question_mode",
        "next_route",
        "last_transition_at"
      ],
      "properties": {
        "protocol_version": {
          "type": "string",
          "enum": ["1.0"]
        },
        "current_phase": {
          "type": "string",
          "enum": [
            "scope",
            "prd",
            "design",
            "adr",
            "plan",
            "exec",
            "fix",
            "status",
            "summary"
          ]
        },
        "completion_status": {
          "type": "string",
          "enum": ["collecting", "ready", "blocked", "done"]
        },
        "question_mode": {
          "type": "string",
          "enum": ["conversation", "checklist", "hybrid"]
        },
        "size": {
          "type": ["string", "null"],
          "enum": ["S", "M", "L", null]
        },
        "needs_design": {
          "type": ["boolean", "null"]
        },
        "needs_adr": {
          "type": ["boolean", "null"]
        },
        "next_route": {
          "type": ["string", "null"],
          "enum": [
            "cx-prd",
            "cx-design",
            "cx-adr",
            "cx-plan",
            "cx-exec",
            "cx-fix",
            "cx-status",
            "cx-summary",
            null
          ]
        },
        "decision_basis": {
          "type": "string"
        },
        "last_transition_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
