{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "cx-workflow 3.0 Config Schema",
  "description": "Configuration schema for 开发文档/CX工作流/配置.json — public project-level settings for cx-workflow",
  "type": "object",
  "required": [
    "version",
    "developer_id",
    "github_sync",
    "current_feature",
    "agent_teams",
    "code_review",
    "auto_memory",
    "worktree_isolation",
    "auto_format",
    "hooks"
  ],
  "properties": {
    "version": {
      "type": "string",
      "description": "Public config schema version",
      "enum": ["3.0"],
      "default": "3.0"
    },
    "developer_id": {
      "type": "string",
      "description": "Per-project developer display name, confirmed by cx-init for each project",
      "minLength": 1,
      "maxLength": 50,
      "example": "承玄"
    },
    "github_sync": {
      "type": "string",
      "description": "GitHub synchronization mode. Project local state remains the runtime source of truth.",
      "enum": ["off", "local", "collab", "full"],
      "default": "local"
    },
    "current_feature": {
      "type": "string",
      "description": "Current active feature slug. Empty string means no active feature.",
      "pattern": "^[a-z0-9_-]*$",
      "example": "vector-memory",
      "default": ""
    },
    "agent_teams": {
      "type": "boolean",
      "description": "Allow cx-exec and cx-fix to use agent teams when task graph complexity warrants it.",
      "default": true
    },
    "code_review": {
      "type": "boolean",
      "description": "Enable post-execution code review gate before cx-summary.",
      "default": true
    },
    "auto_memory": {
      "type": "boolean",
      "description": "Allow workflow commands to maintain lightweight project memory artifacts automatically.",
      "default": true
    },
    "worktree_isolation": {
      "type": "boolean",
      "description": "Prefer isolated git worktrees for larger or multi-step execution sessions.",
      "default": true
    },
    "auto_format": {
      "type": "object",
      "description": "Auto-formatting preferences for post-edit hooks.",
      "required": ["enabled", "formatter"],
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "formatter": {
          "type": "string",
          "enum": ["auto", "prettier", "black", "gofmt"],
          "default": "auto"
        }
      },
      "additionalProperties": false
    },
    "hooks": {
      "type": "object",
      "description": "Public hook toggles. Runtime behavior is implemented by plugin-level hook scripts.",
      "required": [
        "session_start",
        "pre_compact",
        "post_edit_format",
        "notification"
      ],
      "properties": {
        "session_start": {
          "type": "boolean",
          "default": true
        },
        "pre_compact": {
          "type": "boolean",
          "default": true
        },
        "post_edit_format": {
          "type": "boolean",
          "default": true
        },
        "notification": {
          "type": "boolean",
          "default": true
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "description": "Minimal local project",
      "value": {
        "version": "3.0",
        "developer_id": "承玄",
        "github_sync": "off",
        "current_feature": "",
        "agent_teams": true,
        "code_review": true,
        "auto_memory": true,
        "worktree_isolation": true,
        "auto_format": {
          "enabled": true,
          "formatter": "auto"
        },
        "hooks": {
          "session_start": true,
          "pre_compact": true,
          "post_edit_format": true,
          "notification": true
        }
      }
    },
    {
      "description": "Collaborative project with an active feature",
      "value": {
        "version": "3.0",
        "developer_id": "CX Lead",
        "github_sync": "collab",
        "current_feature": "vector-memory",
        "agent_teams": true,
        "code_review": true,
        "auto_memory": true,
        "worktree_isolation": true,
        "auto_format": {
          "enabled": true,
          "formatter": "prettier"
        },
        "hooks": {
          "session_start": true,
          "pre_compact": true,
          "post_edit_format": true,
          "notification": true
        }
      }
    }
  ],
  "notes": [
    "This schema describes the public project-level configuration file 开发文档/CX工作流/配置.json.",
    "Project-level state lives in 开发文档/CX工作流/状态.json and 开发文档/CX工作流/功能/*/状态.json, not in config.",
    "current_feature always stores the stable feature slug, not the Chinese display title.",
    "GitHub remains a synchronization mirror. Project-local 开发文档/CX工作流 + .cx is the runtime source of truth."
  ]
}
